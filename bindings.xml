<Bindings>
    <Layer name="SI_KEYBINDINGS_CATEGORY_GENERAL">
        <Category name="Research Manager">
            <Action name="RESEARCHMANAGER_WINDOW">
                <Down>ResearchManager.UI:ToggleWindow()</Down>
            </Action>
            <Action name="RESEARCHMANAGER_STATUS">
                <Down>ResearchManager.UI:PrintStatus()</Down>
            </Action>
            <Action name="RESEARCHMANAGER_RECOMMEND">
                <Down>ResearchManager.UI:PrintRecommendations(5)</Down>
            </Action>
        </Category>
    </Layer>
</Bindings>
